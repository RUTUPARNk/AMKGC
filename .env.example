# Copy to .env and fill in. Node-LLM System configuration.
DATABASE_URL=postgresql://localhost/node_llm_system
REDIS_URL=redis://localhost:6379

# Neo4j (graph store)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LLM provider: ollama (local) primary, qwen/openai optional
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:latest
QWEN_API_KEY=
OPENAI_API_KEY=

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
SECRET_KEY=
JWT_SECRET_KEY=
